# ── Server Configuration ──
PORT=5050
NODE_ENV=development

# ── CORS / Frontend URLs ──
CORS_ORIGIN_DEV=http://localhost:5173
CORS_ORIGIN_PROD=
FRONTEND_URL=http://localhost:5173

# ── Database (MongoDB) ──
MONGO_URI=

# ── JWT / Auth ──
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRY=7d
ENCRYPTION_ROUND=10

# ── Cloudinary (image uploads) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OpenAI / LLM ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Fast2SMS (OTP & Alert SMS) ──
FAST2SMS_API_KEY=
FAST2SMS_ROUTE=q

# ── Misc ──
DEFAULT_AVATAR_URL=

# ── Frontend (Vite – also place these in frontend/.env if needed) ──
VITE_BASE_URL=http://localhost:5050
VITE_API_URL=http://localhost:5050
